# Render Web Service environment variables
# Copy these into Render's Environment tab.

SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=False
ENABLE_NGROK=False
USE_MANIFEST_STATIC=False

# Render free web service host support
ALLOWED_HOSTS=.onrender.com
CSRF_TRUSTED_ORIGINS=https://*.onrender.com

# Neon Postgres connection string.
# Example format:
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# HTTPS/security settings for Render
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

# Optional email notifications for contact form
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=

# Cloudinary persistent media storage.
# You can set CLOUDINARY_URL instead, or use these three values.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
